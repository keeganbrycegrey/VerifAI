{
    "manifest_version": 3,
    "name": "VerifAI Fact Checker",
    "version": "0.1.0",
    "description": "Philippine Multimodal AI-powered fact checker. Highlight text or right-click images to fact-check instantly.",
    "permissions": [
        "activeTab",
        "storage",
        "scripting",
        "contextMenus"
    ],
    "host_permissions": [
        "<all_urls>"
    ],
    "background": {
        "service_worker": "background.js"
    },
    "content_scripts": [
        {
            "matches": ["<all_urls>"],
            "js": ["content.js"],
            "css": ["panel.css"]
        }
    ],
    "action": {
        "default_popup": "popup.html",
        "default_title": "VerifAI"
    },
    "web_accessible_resources": [
        {
            "resources": [
                "panel.html",
                "panel.css",
                "popup.html",
                "popup.css",
                "popup.js"
            ],
            "matches": ["<all_urls>"]
        }
    ]
}