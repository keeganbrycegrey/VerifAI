{
    "manifest_version": 3,
    "name": "VerifAI Fact Checker",
    "version": "0.1.0",
    "description": "description placeholder",
    "permissions": [
        "activeTab",
        "storage",
        "scripting"
    ],
    "host_permissions": [
        "http://localhost:8000/*"
    ],
    "background": {
        "service_worker": "background.js"
    },
    "content_scripts": [
        {
            "matches": [
                "<all_urls>"
            ],
            "js": [
                "content.js"
            ],
            "css": [
                "panel.css"
            ]
        }
    ],
    "action": {
        "default_popup": "popup.html",
        "default_title": "VerifAI"
    },
    "web_accessible_resources": [
        {
            "resources": [
                "panel.html",
                "panel.css"
            ],
            "matches": [
                "<all_urls>"
            ]
        }
    ]
}
