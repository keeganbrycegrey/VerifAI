# VerifAI environment variables
# copy this file to .env and fill in your actual keys
# NEVER commit .env to GitHub

DEBUG=False

# groq — console.groq.com
GROQ_API_KEY=api key here

# google fact check — console.cloud.google.com
GOOGLE_FACTCHECK_API_KEY=api key here

# huggingface — huggingface.co/settings/tokens
HUGGINGFACE_TOKEN=api key here

# newsapi — newsapi.org/register
NEWSAPI_KEY=api key here

# supabase — supabase.com
SUPABASE_URL=supabase link di2
SUPABASE_ANON_KEY=api key here

# messenger — developers.facebook.com
MESSENGER_PAGE_ACCESS_TOKEN=key here
MESSENGER_VERIFY_TOKEN=token here